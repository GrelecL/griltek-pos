# Cloud backend
POSTGRES_USER=griltek
POSTGRES_PASSWORD=changeme
POSTGRES_DB=griltek_pos
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://griltek:changeme@db:5432/griltek_pos

REDIS_URL=redis://redis:6379/0

SECRET_KEY=change-me-in-production-min-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

ENVIRONMENT=development
LOG_LEVEL=INFO

# Edge store server
EDGE_POSTGRES_USER=griltek_edge
EDGE_POSTGRES_PASSWORD=changeme_edge
EDGE_POSTGRES_DB=griltek_edge
EDGE_DATABASE_URL=postgresql+asyncpg://griltek_edge:changeme_edge@edge-db:5432/griltek_edge

EDGE_REDIS_URL=redis://edge-redis:6379/0

CLOUD_API_URL=https://pos.griltek.com/api/v1
EDGE_SECRET_KEY=change-me-edge-min-32-chars
LOCATION_ID=

# FURS (fiscal)
FURS_ENV=test
FURS_CERT_PATH=/run/secrets/furs_cert
FURS_CERT_PASSWORD=

# SumUp
SUMUP_API_KEY=
SUMUP_MERCHANT_CODE=
